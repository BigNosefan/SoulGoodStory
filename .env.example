# 复制为 .env 并填入你的 key（.env 已被 git 忽略，不会提交到仓库）。
# 设置 DEEPSEEK_API_KEY 后，AI 串联自动改用 DeepSeek；都不设置则用内置 mock。

# DeepSeek（OpenAI 兼容接口，使用 Python 标准库调用，无需额外依赖）
DEEPSEEK_API_KEY=
GOODSTORY_MODEL=deepseek-v4-flash
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# 或者使用 Anthropic Claude（需 pip install anthropic）
# ANTHROPIC_API_KEY=
# GOODSTORY_MODEL=claude-opus-4-8

# 其他可选项
# PORT=5001
# GOODSTORY_SECRET=change-me
